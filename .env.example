# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/volunteer_coordination

# ── Backend API ───────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── AI Microservice ───────────────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8000
NLP_MODEL_NAME=distilbert-base-uncased
NLP_CONFIDENCE_THRESHOLD=0.6
NLP_MAX_LENGTH=128
MAX_DISTANCE_KM=50
AVG_SPEED_KMH=30

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000

# ── Pipeline ──────────────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:4000
